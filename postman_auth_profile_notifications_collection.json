  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://b-i.test"
    },
    {
      "key": "auth_token",
      "value": ""
    },
    {
      "key": "accept_language",
      "value": "ar"
    }
  ],
  "item": [
