{
  "info": {
    "_postman_id": "4f7d4db7-8c91-4b64-b2bb-9d37a0f0e8a1",
    "name": "B&I Auth Profile Notifications",
    "description": "Postman collection for auth profile, password, logout, and notification settings endpoints.",
