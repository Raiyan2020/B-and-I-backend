{
  "openapi": "3.0.3",
  "info": {
    "title": "B&I API",
    "description": "Public API (v1). Investor directory and general endpoints.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api",
      "description": "API base (same origin)"
    }
  ],
  "paths": {
    "/v1/general/investors": {
      "get": {
        "tags": ["General"],
        "summary": "List investors (public directory)",
        "description": "Paginated list of active investors with optional filters. Capital filters use `available_capital` (Kuwaiti Dinar). Send `Accept-Language` (e.g. `ar`, `en`) for localized enum labels and sector names.",
        "parameters": [
          {
            "name": "investor_type",
            "in": "query",
            "required": false,
            "description": "Filter by investor type (matches reference `GET /v1/general/investor-types`).",
            "schema": {
              "type": "string",
              "enum": ["angel", "company", "crowdfunding"]
            }
          },
          {
            "name": "min_capital",
            "in": "query",
            "required": false,
            "description": "Minimum available capital (inclusive).",
            "schema": {
              "type": "number",
              "minimum": 0,
              "example": 10000
            }
          },
          {
            "name": "max_capital",
            "in": "query",
            "required": false,
            "description": "Maximum available capital (inclusive). Must be >= `min_capital` when both are sent.",
            "schema": {
              "type": "number",
              "minimum": 0,
              "example": 500000
            }
          },
          {
            "name": "investor_experience",
            "in": "query",
            "required": false,
            "description": "Filter by investment experience (matches reference `GET /v1/general/investor-experience`).",
            "schema": {
              "type": "string",
              "enum": ["beginner", "intermediate", "expert"]
            }
          },
          {
            "name": "preferred_sector_id",
            "in": "query",
            "required": false,
            "description": "Filter by preferred sector id (matches reference `GET /v1/general/preferred-sectors`).",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "example": 3
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number for pagination.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "description": "Items per page (max 100).",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 15
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "key": { "type": "string", "example": "success" },
                    "msg": { "type": "string" },
                    "code": { "type": "integer", "example": 200 },
                    "response_status": {
                      "type": "object",
                      "properties": {
                        "error": { "type": "boolean", "example": false },
                        "validation_errors": {
                          "type": "array",
                          "items": { "type": "object" }
                        }
                      }
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "investors": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/PublicInvestor" }
                        },
                        "pagination": { "$ref": "#/components/schemas/Pagination" }
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation error (e.g. invalid filter or max_capital < min_capital)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PublicInvestor": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 8921 },
          "display_id": { "type": "string", "example": "USR-8921" },
          "investor_type": {
            "type": "object",
            "properties": {
              "value": { "type": "string", "enum": ["angel", "company", "crowdfunding"] },
              "label": { "type": "string", "description": "Localized label" }
            }
          },
          "available_capital": {
            "type": "number",
            "format": "float",
            "nullable": true,
            "description": "Available capital amount (KWD)"
          },
          "focus_sector": {
            "type": "object",
            "nullable": true,
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string", "description": "Localized sector name" }
            }
          },
          "investment_experience": {
            "type": "object",
            "properties": {
              "value": { "type": "string", "enum": ["beginner", "intermediate", "expert"] },
              "label": { "type": "string", "description": "Localized label" }
            }
          },
          "image": { "type": "string", "format": "uri", "description": "Profile image URL" }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "current_page": { "type": "integer" },
          "last_page": { "type": "integer" },
          "per_page": { "type": "integer" },
          "total": { "type": "integer" }
        }
      },
      "ValidationErrorResponse": {
        "type": "object",
        "description": "Laravel validation error shape (may vary by app exception handler)",
        "properties": {
          "message": { "type": "string" },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
