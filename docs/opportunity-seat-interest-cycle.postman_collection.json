{
  "info": {
    "name": "B&I Opportunity Seat + Interest Cycle",
    "_postman_id": "c56a5fcf-4f85-4e68-bf0e-f9f6f79b5c77",
    "description": "Collection to test the investor cycle: login, browse opportunities, buy seat, unlock details, and submit interest.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Investor Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept-Language",
            "value": "{{locale}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{investor_email}}\",\n  \"password\": \"{{investor_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json?.data?.token) {",
              "  pm.collectionVariables.set('auth_token', json.data.token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "General - List Opportunities",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept-Language",
            "value": "{{locale}}"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/general/opportunities",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "general",
            "opportunities"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "const firstOpportunity = json?.data?.opportunities?.[0];",
              "if (firstOpportunity?.id) {",
              "  pm.collectionVariables.set('opportunity_id', firstOpportunity.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "General - Opportunity Details Before Seat",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept-Language",
            "value": "{{locale}}"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/general/opportunities/{{opportunity_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "general",
            "opportunities",
            "{{opportunity_id}}"
          ]
        }
      }
    },
    {
      "name": "General - Buy Investment Seat",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept-Language",
            "value": "{{locale}}"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/general/opportunities/{{opportunity_id}}/seats",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "general",
            "opportunities",
            "{{opportunity_id}}",
            "seats"
          ]
        }
      }
    },
    {
      "name": "General - Opportunity Details After Seat",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept-Language",
            "value": "{{locale}}"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/general/opportunities/{{opportunity_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "general",
            "opportunities",
            "{{opportunity_id}}"
          ]
        }
      }
    },
    {
      "name": "General - Submit Interest Request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept-Language",
            "value": "{{locale}}"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/general/opportunities/{{opportunity_id}}/interest-requests",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "general",
            "opportunities",
            "{{opportunity_id}}",
            "interest-requests"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "locale",
      "value": "ar"
    },
    {
      "key": "investor_email",
      "value": "maya.investor@bi.test"
    },
    {
      "key": "investor_password",
      "value": "Password@123"
    },
    {
      "key": "auth_token",
      "value": ""
    },
    {
      "key": "opportunity_id",
      "value": ""
    }
  ]
}
